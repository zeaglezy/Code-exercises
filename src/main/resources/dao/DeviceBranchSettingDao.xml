<?xml version="1.0" encoding="utf-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.example.demo.dao.DeviceBranchSettingDao">

    <resultMap id="map" type="com.example.demo.domain.BranchSettingSummary">
        <id column="USER_ID" property="orgId"></id>
        <result column="USER_NAME" property="userName"></result>
        <result column="PASSWORD" property="passWord"></result>
    </resultMap>
    <select id="listBranchSettingSummary" resultMap="map">
         SELECT
          USER_ID,USER_NAME,PASSWORD
         FROM user
         where
         USER_ID=#{orgId}
    </select>
</mapper>